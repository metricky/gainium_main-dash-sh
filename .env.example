# Self-hosted Gainium dashboard — example env.
#
# Copy to `.env` (or `.env.development` / `.env.production`) and fill in
# the values that match your local app-sh backend.

# --------------------------------------------------------------------
# Backend
# --------------------------------------------------------------------

# VITE_API_ENDPOINT — URL of the app-sh backend (GraphQL + REST).
# Point at your local app-sh instance, or wherever you run it.
VITE_API_ENDPOINT=http://localhost:7500

# --------------------------------------------------------------------
# Build mode + logging
# --------------------------------------------------------------------

MODE=development

# VITE_LOG_LEVEL — DEBUG | INFO | WARN | ERROR (default DEBUG in dev,
# INFO in prod).
# VITE_LOG_LEVEL=INFO

# --------------------------------------------------------------------
# Build mode
# --------------------------------------------------------------------
#
# `VITE_MODE=sh` is the default and produces the lightweight build
# served by this repo. Cloud's own build script overrides this to
# `cloud` to enable the cloud-only surfaces. Sh users almost never
# need to set this manually.

# VITE_MODE=sh
